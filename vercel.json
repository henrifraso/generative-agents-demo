{
  "version": 2,
  "alias": ["tbg-studio.vercel.app"],
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "100mb" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/index.py" }
  ],
  "buildCommand": "python manage.py collectstatic --noinput --settings=frontend_server.settings.production"
}
